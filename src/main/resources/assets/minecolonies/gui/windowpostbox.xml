<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="440 244">
    <image pos="0 0" size="440 244" source="minecolonies:textures/gui/citizen/colonist_paper.png"/>

    <text color="black" id="desc" label="$(com.minecolonies.coremod.gui.citizen.stacks)" pos="60 14" size="130 11" textalign="MIDDLE"/>
    <input id="name" maxlength="25" pos="50 30" size="150 18"/>

    <list id="resources" pos="33 50" size="215 136">
        <box linewidth="1" size="100% 18">
            <itemicon id="resourceIcon" pos="0 0" size="17 17"/>
            <text color="black" id="resourceName" pos="20 1" size="100 12"/>
            <input id="qty" maxlength="25" pos="113 1" size="25 18"/>

            <button
                color="black"
                id="request"
                label="$(com.minecolonies.coremod.gui.workerhuts.request)"
                pos="140 1"
                size="64 15"
                source="minecolonies:textures/gui/builderhut/builder_button_small.png"/>
        </box>
    </list>

    <text color="black" label="$(com.minecolonies.coremod.gui.citizen.requests)" pos="236 28" size="158 11" textalign="MIDDLE"/>
    <list id="requests" pos="256 44" size="158 184">
        <box id="requestx" linewidth="1" size="100% 40">
            <layout source="minecolonies:gui/layouthuts/layoutrequeststree.xml"/>
        </box>
    </list>

    <button id="deliverAvailable" pos="42 195" size="40 15"/>
    <text color="black" id="test" label="Deliver what&apos;s available" pos="90 195" size="158 11"/>
    <button color="black" id="inventory" label="$(container.inventory)" pos="97 210" size="86 17" source="minecolonies:textures/gui/builderhut/builder_button_medium.png"/>
</window>
