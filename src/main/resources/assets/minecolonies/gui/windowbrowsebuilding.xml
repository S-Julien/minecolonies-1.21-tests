<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image size="100% 100%" source="minecolonies:textures/gui/builderhut/builder_paper_sketch.png"/>
    <image pos="175 180" size="19 59" source="minecolonies:textures/gui/builderhut/builder_charcoal_chalk.png"/>

    <image pos="44 12" size="6 15" source="minecolonies:textures/gui/builderhut/builder_sketch_left.png"/>
    <image pos="50 12" size="90 15" source="minecolonies:textures/gui/builderhut/builder_sketch_center.png"/>
    <image pos="140 12" size="6 15" source="minecolonies:textures/gui/builderhut/builder_sketch_right.png"/>
    <text color="blue" id="constructionName" pos="50 14" size="90 11" textalign="MIDDLE"/>

    <text color="green" id="loading" label="$(com.minecolonies.command.gui.browsebuilding.loading)" pos="50 116" size="90 11" textalign="MIDDLE"/>
    <image id="progress" pos="50 130" size="0 16" source="minecolonies:progress_block"/>

    <list id="buildings" pos="15 30" size="162 80%" visible="false">
        <box linewidth="1" size="100% 32">
            <text color="black" id="packName" pos="2 2" size="158 10"/>
            <text color="black" id="buildingName" pos="2 11" size="158 10" textscale="0.5" wrap="true"/>
            <text color="black" id="buildingSize" pos="2 21" size="69% 10"/>
            <text align="TOP_RIGHT" color="black" id="buildingLevel" pos="2 21" size="29% 10" textalign="TOP_RIGHT"/>
        </box>
    </list>
</window>
