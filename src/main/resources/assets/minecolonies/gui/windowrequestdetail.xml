<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 133">
    <image size="100% 100%" source="minecolonies:textures/gui/citizen/colonist_paper.png"/>

    <text color="black" label="$(com.minecolonies.coremod.gui.citizen.requests)" pos="0 13" size="190 11" textalign="MIDDLE"/>

    <itemicon id="requestStack" pos="12 30" size="24 24"/>
    <image id="deliveryImage" pos="12 30" size="24 24" source="minecraft:textures/misc/shadow.png" visible="false"/>

    <text color="black" id="requester" pos="40 30" size="135 9"/>
    <text color="black" id="targetLocation" pos="40 40" size="135 9"/>
    <text color="black" id="resolver" pos="40 50" size="135 9"/>

    <text color="black" id="shortDetail" pos="12 60" size="170 40"/>
    <itemicon id="detailIcon" pos="80 75" size="9 9"/>

    <button color="black" id="back" label="$(com.minecolonies.coremod.gui.back)" pos="35 105" size="37 16" source="minecolonies:textures/gui/citizen/colonist_button_small.png"/>

    <button color="black" id="fulfill" label="$(com.minecolonies.coremod.gui.citizen.requestsfulfill)" pos="76 105" size="37 16" source="minecolonies:textures/gui/citizen/colonist_button_small.png"/>

    <button color="black" id="cancel" label="$(com.minecolonies.coremod.gui.citizen.requestscancel)" pos="117 105" size="37 16" source="minecolonies:textures/gui/citizen/colonist_button_small.png"/>
