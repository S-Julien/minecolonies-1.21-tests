<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd">
    <image size="400 244" source="minecolonies:textures/gui/builderhut/builder_paper_wide2.png"/>

    <text color="black" id="jobLabel" pos="0 15" size="100% 11" textalign="MIDDLE"/>
    <list id="unemployed" pos="20 48" size="375 135">
        <view size="100% 35">
            <gradient gradientend="430265344" gradientstart="430265344" size="100% 100%"/>
            <text color="blue" id="citizen" pos="5 0" size="175 12"/>
            <text color="black" id="distance" pos="2 10" size="300 8" textscale="0.8"/>
            <text color="black" id="attributes" pos="2 18" size="300 16" textscale="0.7"/>

            <button
                color="black"
                id="done"
                label="$(com.minecolonies.coremod.gui.hiring.buttonhire)"
                pos="200 2"
                size="44 10"
                source="minecolonies:textures/gui/builderhut/builder_button_quite_small.png"
                textscale="0.8"/>
            <button
                color="black"
                id="fire"
                label="$(com.minecolonies.coremod.gui.hiring.buttonfire)"
                pos="200 2"
                size="44 10"
                source="minecolonies:textures/gui/builderhut/builder_button_quite_small.png"
                textscale="0.8"/>

            <button color="black" id="pause" label="" pos="250 2" size="44 10" source="minecolonies:textures/gui/builderhut/builder_button_quite_small.png" textscale="0.8"/>

            <button
                color="black"
                id="restart"
                label="$(com.minecolonies.coremod.gui.hiring.restart)"
                pos="300 2"
                size="44 10"
                source="minecolonies:textures/gui/builderhut/builder_button_quite_small.png"
                textscale="0.8"/>
        </view>
    </list>

    <text color="black" id="buildingHireMode" label="$(com.minecolonies.coremod.gui.buildinghiremode)" pos="20 189" size="200 11"/>
    <button color="black" id="mode" label="$(com.minecolonies.coremod.gui.workerhuts.manage)" pos="150 187" size="169 17" source="minecolonies:textures/gui/builderhut/builder_button_large.png"/>

    <text color="black" id="showEmployedLabel" label="$(com.minecolonies.coremod.gui.showemployed)" pos="20 210" size="120 11"/>

    <button color="black" id="showEmployed" label="$(gui.no)" pos="200 208" size="29 17" source="minecolonies:textures/gui/builderhut/builder_button_very_small.png"/>

    <button color="black" id="cancel" pos="375 10" size="14 15" source="minecolonies:textures/gui/button_x.png"/>
</window>
