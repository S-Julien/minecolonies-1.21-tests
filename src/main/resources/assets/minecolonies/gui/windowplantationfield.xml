<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 130">
    <image size="190 130" source="minecolonies:textures/gui/builderhut/builder_paper_short.png"/>
    <image pos="44 12" size="6 15" source="minecolonies:textures/gui/builderhut/builder_sketch_left.png"/>
    <image pos="50 12" size="90 15" source="minecolonies:textures/gui/builderhut/builder_sketch_center.png"/>
    <image pos="140 12" size="6 15" source="minecolonies:textures/gui/builderhut/builder_sketch_right.png"/>
    <text color="red" label="$(block.minecolonies.blockhutplantationfield)" pos="30 14" size="130 11" textalign="MIDDLE"/>

    <text color="black" id="not-in-colony" label="$(com.minecolonies.coremod.gui.workerhuts.fields.notincolony)" pos="13 55" size="164 11" textalign="MIDDLE"/>

    <text color="black" id="plants-header" label="$(com.minecolonies.coremod.gui.workerhuts.plantationfields.plants)" pos="30 30" size="130 11" textalign="MIDDLE"/>

    <list id="plants" pos="30 45" size="138 32">
        <view size="130 32">
            <box pos="4 4" size="24 24">
                <itemicon id="icon1" pos="4 4" size="16 16"/>
            </box>
            <box pos="36 4" size="24 24">
                <itemicon id="icon2" pos="4 4" size="16 16"/>
            </box>
            <box pos="68 4" size="24 24">
                <itemicon id="icon3" pos="4 4" size="16 16"/>
            </box>
            <box pos="100 4" size="24 24">
                <itemicon id="icon4" pos="4 4" size="16 16"/>
            </box>
        </view>
    </list>

    <button
        color="black"
        id="repair"
        label="$(com.minecolonies.coremod.gui.workerhuts.plantationfields.repair)"
        pos="30 90"
        size="130 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>
</window>
