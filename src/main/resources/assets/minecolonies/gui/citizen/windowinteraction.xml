<window lightbox="true" size="350 170">
    <switch id="head" pos="0 0" size="100% 100%">
        <view id="interactionView">
            <gradient id="gradient" pos="20 0" size="300 170"/>
            <text color="white" id="chat" pos="30 15" size="250 100"/>
            <box id="responseOptions" linewidth="0" pos="30 100" size="270 70"/>

            <itemicon id="requestItem" pos="30 60" size="32 32"/>
        </view>
    </switch>
    <button color="black" id="cancel" pos="303 1" size="14 15" source="minecolonies:textures/gui/button_x.png" tooltip="$(com.minecolonies.core.exit_interactions)"/>
</window>
