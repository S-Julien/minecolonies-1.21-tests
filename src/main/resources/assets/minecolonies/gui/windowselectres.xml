<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    lightbox="true">
    <text color="white" label="$(com.minecolonies.coremod.gui.scan.select.title)" pos="0 25" size="100% 11" textalign="TOP_MIDDLE"/>

    <input id="name" maxlength="25" pos="135 40" size="150 18"/>

    <itemicon id="resourceIcon" pos="70 1" size="17 17"/>
    <text color="white" id="resourceName" pos="100 4" size="140 12"/>

    <input id="qty" maxlength="25" pos="200 2" size="25 14"/>
    <text id="qtylabel" label="$(com.minecolonies.coremod.gui.scan.select.stack)" pos="235 4" size="50 12"/>

    <list id="resources" pos="60 65" size="300 120">
        <box linewidth="1" size="100% 17">
            <itemicon id="resourceIcon" pos="1 1" size="17 17"/>
            <text color="white" id="resourceName" pos="30 1" size="140 12"/>
            <button color="black" id="select" label="$(com.minecolonies.coremod.gui.scantool.select)" pos="160 1" size="86 17" source="minecolonies:textures/gui/builderhut/builder_button_medium.png"/>
        </box>
    </list>

    <button id="done" pos="125 185" size="32" source="minecolonies:textures/gui/buildtool/confirm.png"/>
    <button id="cancel" pos="215 185" size="32" source="minecolonies:textures/gui/buildtool/cancel.png"/>
</window>
