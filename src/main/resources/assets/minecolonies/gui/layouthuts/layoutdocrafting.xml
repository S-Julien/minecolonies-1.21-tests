<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>
    <text color="black" label="$(com.minecolonies.coremod.gui.docrafting)" pos="30 14" size="130 11" textalign="MIDDLE"/>

    <list id="resources" pos="20 35" size="135 57">
        <view size="100% 17">
            <text color="black" id="resourceName" pos="0 2" size="40 12"/>
            <itemicon id="resourceIcon" pos="40 0" size="17 17"/>
            <button
                color="black"
                id="resourceAdd"
                label="$(com.minecolonies.coremod.gui.docrafting.switch)"
                pos="60 0"
                size="64 15"
                source="minecolonies:textures/gui/builderhut/builder_button_small.png"/>
        </view>
    </list>

    <button id="request" pos="155 51" size="16 16" source="minecolonies:textures/gui/citizen/detail_button.png" tooltip="$(com.minecolonies.coremod.gui.citizen.requesttitle)"/>

    <list id="resourcesstock" pos="13 100" size="170 100">
        <box linewidth="1" size="100% 17">
            <itemicon id="resourceIcon" pos="0 0" size="17 17"/>
            <text color="black" id="resourceName" pos="20 1" size="90 12"/>
            <text color="black" id="resourceQty" pos="115 1" size="12 12"/>
        </box>
    </list>

    <button color="black" id="add" label="$(com.minecolonies.coremod.gui.docrafting.teach)" pos="60 210" size="64 17" source="minecolonies:textures/gui/builderhut/builder_button_small.png"/>
</window>
