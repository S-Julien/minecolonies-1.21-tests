<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>

    <image pos="24 12" size="6 15" source="minecolonies:textures/gui/builderhut/builder_sketch_left.png"/>
    <image pos="30 12" size="130 15" source="minecolonies:textures/gui/builderhut/builder_sketch_center.png"/>
    <image pos="160 12" size="6 15" source="minecolonies:textures/gui/builderhut/builder_sketch_right.png"/>
    <text color="red" id="name" pos="30 14" size="128 11" textalign="MIDDLE"/>
    <button id="editName" pos="150 11" size="15 15" source="minecolonies:textures/gui/builderhut/edit.png" tooltip="$(com.minecolonies.gui.edit)"/>

    <button
        color="black"
        id="build"
        label="$(com.minecolonies.coremod.gui.workerhuts.buildrepair)"
        pos="30 110"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>
    <button id="info" pos="14 214" size="17 17" source="minecolonies:textures/gui/red_wax_information.png" tooltip="$(com.minecolonies.core.building.help)"/>
</window>
