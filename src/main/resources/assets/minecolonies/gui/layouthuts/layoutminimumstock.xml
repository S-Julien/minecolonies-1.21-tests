<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>
    <text color="black" label="$(com.minecolonies.coremod.gui.warehouse.stock)" pos="30 14" size="130 11" textalign="MIDDLE"/>
    <list emptycolor="black" emptytext="$(com.minecolonies.coremod.gui.warehouse.stock.empty)" id="resourcesstock" pos="13 50" size="170 180">
        <box linewidth="1" size="100% 17">
            <itemicon id="resourceIcon" pos="0 0" size="17 17"/>
            <text color="black" id="resourceName" pos="20 1" size="90 12"/>
            <text color="black" id="resourceQty" pos="115 1" size="12 12"/>

            <button color="red" id="removeStock" label="X" pos="130 1" size="29 15" source="minecolonies:textures/gui/builderhut/builder_button_very_small.png"/>
        </box>
    </list>
    <button color="black" id="addStock" label="$(com.minecolonies.coremod.gui.warehouse.add)" pos="50 30" size="86 17" source="minecolonies:textures/gui/builderhut/builder_button_medium.png"/>
</window>
