<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>
    <text color="black" label="$(com.minecolonies.core.gui.modules.stats)" pos="30 14" size="130 11" textalign="MIDDLE"/>
    <view pos="0 0" size="200 243">
        <dropdown color="black" dropDownSize="140 75" id="intervals" maxContentHeight="75" pos="30 30" size="129 17" source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png">
            <button
                color="black"
                id="button"
                label="$(com.minecolonies.coremod.gui.interval.yesterday)"
                pos="0 0"
                size="129 17"
                source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>
        </dropdown>
        <list emptycolor="black" emptytext="$(com.minecolonies.core.gui.modules.stats.empty)" id="stats" pos="20 55" size="160 160">
            <text color="black" id="desc" pos="0 0" size="160 13"/>
        </list>
    </view>
</window>
