<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>
    <text color="black" label="$(com.minecolonies.coremod.gui.warehouse.upgrade)" pos="30 14" size="130 11" textalign="MIDDLE"/>
    <box linewidth="1" pos="13 29" size="164 30">
        <itemicon id="resourceIcon" pos="1 1" size="16 16"/>
        <text color="black" id="resourceName" pos="18 2" size="125 9"/>
        <button id="resourceAdd" label="↥" pos="145 2" size="16 16"/>
        <text color="black" id="resourceMissing" pos="2 20" size="65 9" textalign="MIDDLE"/>
        <text color="black" id="resourceAvailableNeeded" pos="67 20" size="65 9" textalign="MIDDLE"/>
        <text color="black" id="upgradeProgress" pos="132 20" size="40 9"/>

        <text id="resourceId" pos="100 100" size="1 1"/>
        <text id="resourceQuantity" pos="100 100" size="1 1"/>
    </box>
    <button
        color="black"
        disabled="minecolonies:textures/gui/builderhut/builder_button_medium_large_disabled.png"
        id="sort"
        label="$(com.minecolonies.coremod.gui.warehouse.sort)"
        pos="50 70"
        size="86 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium.png"/>
</window>
