<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>
    <text color="black" label="$(com.minecolonies.coremod.gui.citizen.requests)" pos="30 14" size="120 11" textalign="MIDDLE"/>
    <button color="red" id="cancel" label="X" pos="160 11" size="14 15" source="minecolonies:textures/gui/builderhut/builder_button_mini.png"/>

    <list id="requests" pos="13 30" size="170 170">
        <box id="requestx" linewidth="1" size="100% 40">
            <!--Item icon -->
            <itemicon id="requestStack" pos="1 3" size="16 16"/>
            <image id="deliveryImage" pos="1 3" size="16 16" source="minecraft:textures/misc/shadow.png" visible="false"/>

            <!--Request name-->
            <text color="black" id="shortDetail" pos="20 1" size="130 12"/>
            <text color="black" id="requester" pos="20 13" size="130 12"/>

            <button color="black" id="select" label="$(com.minecolonies.coremod.gui.scantool.select)" pos="20 23" size="37 16" source="minecolonies:textures/gui/builderhut/builder_button_small.png"/>
        </box>
    </list>
</window>
