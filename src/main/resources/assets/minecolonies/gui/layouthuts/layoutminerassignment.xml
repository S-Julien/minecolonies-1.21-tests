<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>
    <text color="black" label="$(com.minecolonies.coremod.gui.workerhuts.workerassigned)" pos="13 32" size="164 11" textalign="MIDDLE"/>

    <list id="workers" pos="13 43" size="164 30">
        <view size="100% 11">
            <box linewidth="0" size="100% 11">
                <text color="black" id="workerName" pos="0 0" size="100% 11" textalign="MIDDLE"/>
            </box>
        </view>
    </list>

    <button color="black" id="hire" label="$(com.minecolonies.coremod.gui.workerhuts.manage)" pos="30 74" size="129 17" source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>
    <button
        color="black"
        id="recall"
        label="$(com.minecolonies.coremod.gui.workerhuts.recall)"
        pos="30 92"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>
    <text color="black" id="text" pos="30 120" size="150 45" text="$(com.minecolonies.coremod.gui.quarry.desc)"/>
</window>
