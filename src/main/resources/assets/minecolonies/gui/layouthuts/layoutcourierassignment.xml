<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>
    <text color="black" label="$(com.minecolonies.coremod.gui.workerhuts.workerassigned)" pos="13 22" size="164 11" textalign="MIDDLE"/>

    <list id="workers" pos="13 43" size="164 110">
        <view size="100% 11">
            <box linewidth="0" size="100% 11">
                <text color="black" id="workerName" pos="0 0" size="100% 11" textalign="MIDDLE"/>
            </box>
        </view>
    </list>

    <button
        id="hire"
        label="$(com.minecolonies.coremod.gui.workerhuts.manage)"
        pos="30 154"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"
        textcolor="black"/>
    <button
        id="recall"
        label="$(com.minecolonies.coremod.gui.workerhuts.recall)"
        pos="30 172"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"
        textcolor="black"/>
</window>
