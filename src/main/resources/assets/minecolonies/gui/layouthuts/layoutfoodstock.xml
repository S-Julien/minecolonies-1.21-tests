<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="380 255">
    <image size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>
    <text color="black" id="title" label="$(com.minecolonies.core.menu.title)" pos="30 14" size="130 11" textalign="MIDDLE"/>
    <text color="black" id="warning" label="$(com.minecolonies.core.menu.warning)" pos="13 50" size="150 22" textalign="MIDDLE"/>
    <text color="red" id="poorwarning" label="$(com.minecolonies.core.poor.menu.warning)" pos="14 25" size="160 22" textalign="MIDDLE" visible="false"/>

    <list id="resourcesstock" pos="13 50" size="164 180">
        <box linewidth="1" size="100% 17">
            <gradient id="gradient" pos="1 1" size="162 15"/>
            <itemicon id="resourceIcon" pos="0 0" size="16 16"/>
            <text color="black" id="resourceName" pos="20 1" size="100 12"/>

            <button id="removeStock" label="X" pos="126 1" size="29 15" source="minecolonies:textures/gui/builderhut/builder_button_very_small.png" textcolor="red"/>
        </box>
    </list>

    <image pos="190 0" size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>
    <text color="black" id="desc" label="$(com.minecolonies.core.food_list.title)" pos="220 14" size="130 11" textalign="MIDDLE"/>
    <input id="input" maxlength="25" pos="210 28" size="150 18"/>

    <list id="resources" pos="203 50" size="164 180">
        <box linewidth="1" size="100% 17">
            <gradient id="gradient" pos="1 1" size="162 15"/>
            <itemicon id="resourceIcon" pos="20 0" size="16 16"/>
            <text color="white" id="resourceName" pos="40 3" size="100 12"/>
            <button id="switch" label="&lt;&lt;" pos="3 1" size="14 15" source="minecolonies:textures/gui/builderhut/builder_button_mini.png" textcolor="black"/>
        </box>
    </list>
</window>
