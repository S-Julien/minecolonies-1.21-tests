<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>
    <text color="black" id="desc" pos="30 14" size="130 11" textalign="MIDDLE"/>
    <input id="input" maxlength="25" pos="20 30" size="150 18"/>

    <list id="resources" pos="13 50" size="164 136">
        <box linewidth="1" size="100% 17">
            <text color="white" id="resourceName" pos="2 1" size="100 12"/>
            <button
                color="black"
                id="switch"
                label="$(com.minecolonies.coremod.gui.workerhuts.retrieveOn)"
                pos="120 1"
                size="29 15"
                source="minecolonies:textures/gui/builderhut/builder_button_very_small.png"/>
        </box>
    </list>
    <button
        color="black"
        id="resetDefault"
        label="$(com.minecolonies.coremod.gui.workerhuts.resetdefault)"
        pos="50 194"
        size="86 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium.png"/>
</window>
