<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>
    <text color="black" label="$(com.minecolonies.coremod.gui.workerhuts.fields)" pos="30 14" size="130 11" textalign="MIDDLE"/>
    <text color="black" id="AssignmentModeLabel" label="$(com.minecolonies.coremod.gui.workerhuts.fields.assignmentmode)" pos="13 29" size="164 11" textalign="MIDDLE"/>
    <button
        color="black"
        disabled="minecolonies:textures/gui/builderhut/builder_button_medium_disabled.png"
        id="assignmentMode"
        label="$(com.minecolonies.coremod.gui.hiring.off)"
        pos="52 42"
        size="86 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium.png"/>
    <text color="black" id="fieldCount" label="$(com.minecolonies.coremod.gui.workerhuts.fields.fieldcount)" pos="13 69" size="164 11" textalign="MIDDLE"/>

    <list id="fields" pos="13 82" size="164 143">
        <box linewidth="1" size="100% 24">
            <itemicon id="icon" pos="4 4" size="16 16"/>
            <text color="black" id="dist" pos="25 8" size="108 9"/>

            <button
                disabled="minecolonies:textures/gui/builderhut/builder_button_mini_disabled.png"
                id="assign"
                pos="137 4"
                size="14 15"
                source="minecolonies:textures/gui/builderhut/builder_button_mini.png"/>
        </box>
    </list>
</window>
