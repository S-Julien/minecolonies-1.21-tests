<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>
    <text color="black" label="$(com.minecolonies.coremod.gui.workerhuts.listrecipes)" pos="30 14" size="130 11" textalign="MIDDLE"/>

    <text color="black" id="recipestatus" pos="70 30" size="100% 11"/>
    <list id="recipes" pos="20 40" size="85% 150">
        <view size="100% 50">
            <gradient gradientend="rgb(160,160,160)" gradientstart="rgb(160,160,160)" id="gradient" pos="0 0" size="100% 100%" visible="false"/>
            <itemicon id="output" pos="80 17" size="16 16"/>
            <box id="3x3" linewidth="1" size="100% 50">
                <itemicon id="res1" pos="20 1" size="16 16"/>
                <itemicon id="res2" pos="34 1" size="16 16"/>
                <itemicon id="res3" pos="48 1" size="16 16"/>

                <itemicon id="res4" pos="20 15" size="16 16"/>
                <itemicon id="res5" pos="34 15" size="16 16"/>
                <itemicon id="res6" pos="48 15" size="16 16"/>

                <itemicon id="res7" pos="20 29" size="16 16"/>
                <itemicon id="res8" pos="34 29" size="16 16"/>
                <itemicon id="res9" pos="48 29" size="16 16"/>
            </box>
            <button id="up" label="↥" pos="0 0" size="15 15"/>
            <button id="down" label="↧" pos="0 15" size="15 15"/>
            <button id="remove" label="$(com.minecolonies.coremod.gui.recipe.remove)" pos="105 3" size="45 15"/>
            <button id="toggle" label="$(com.minecolonies.coremod.gui.recipe.disable)" pos="105 18" size="45 15"/>
            <text color="black" id="intermediate" pos="105 33" size="45 15" textalign="MIDDLE"/>
        </view>
    </list>

    <button
        color="black"
        id="crafting"
        label="$(com.minecolonies.coremod.gui.workerhuts.crafting)"
        pos="30 200"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>
</window>
