<window>
    <image id="deliveryImage" pos="1 3" size="16 16" source="minecraft:textures/misc/shadow.png" visible="false"/>
    <button id="detail" pos="1 23" size="16 16" source="minecolonies:textures/gui/citizen/detail_button.png"/>
    <itemicon id="requestStack" pos="1 3" size="16 16"/>

    <text color="black" id="shortDetail" pos="20 2" size="130 9"/>
    <itemicon id="detailIcon" pos="85 1" size="9 9"/>

    <text color="black" id="requester" pos="20 13" size="130 9"/>

    <!-- Color green if possible? -->
    <button
        id="fulfill"
        label="$(com.minecolonies.coremod.gui.citizen.requestsfulfill)"
        pos="20 23"
        size="37 16"
        source="minecolonies:textures/gui/citizen/colonist_button_small.png"
        textcolor="black"/>

    <!-- button to cancel the request-->
    <button id="cancel" label="$(com.minecolonies.coremod.gui.citizen.requestscancel)" pos="70 23" size="37 16" source="minecolonies:textures/gui/citizen/colonist_button_small.png" textcolor="black"/>
</window>
