<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>
    <text color="black" label="$(com.minecolonies.coremod.gui.workerhuts.minernodelist)" pos="30 14" size="130 11" textalign="MIDDLE"/>
    <list emptycolor="black" emptytext="$(com.minecolonies.coremod.gui.workerhuts.minernolevels)" id="levels" pos="13 29" size="164 185">
        <box linewidth="1" size="100% 28">
            <text color="black" id="level" pos="3 2" size="17 12" textalign="MIDDLE_LEFT"/>
            <text color="black" id="depth" pos="23 2" size="60 12" textalign="MIDDLE_LEFT"/>
            <text color="black" id="nodes" pos="23 15" size="60 12" textalign="MIDDLE_LEFT"/>

            <button
                color="black"
                disabled="minecolonies:textures/gui/builderhut/builder_button_quite_small_disabled.png"
                id="repair"
                label="$(com.minecolonies.coremod.gui.workerhuts.minerrepairnode)"
                pos="88 6"
                size="44 17"
                source="minecolonies:textures/gui/builderhut/builder_button_quite_small.png"/>
            <button
                disabled="minecolonies:textures/gui/builderhut/builder_button_mini_check.png"
                id="mine"
                pos="135 6"
                size="17 17"
                source="minecolonies:textures/gui/builderhut/builder_button_mini.png"/>
        </box>
    </list>
</window>
