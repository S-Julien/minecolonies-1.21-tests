<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image size="100% 100%" source="minecolonies:textures/gui/builderhut/builder_paper_sketch.png"/>
    <image pos="34 12" size="6 15" source="minecolonies:textures/gui/builderhut/builder_sketch_left.png"/>
    <image pos="40 12" size="110 15" source="minecolonies:textures/gui/builderhut/builder_sketch_center.png"/>
    <image pos="150 12" size="6 15" source="minecolonies:textures/gui/builderhut/builder_sketch_right.png"/>

    <text color="black" label="$(com.minecolonies.coremod.item.questlog.gui.title)" pos="0 14" size="100% 11" textalign="MIDDLE"/>

    <button id="prevPage" pos="13 13" size="18 10" source="minecolonies:textures/gui/builderhut/turn_page_left.png"/>
    <button id="nextPage" pos="159 13" size="18 10" source="minecolonies:textures/gui/builderhut/turn_page_right.png"/>

    <switch endless="true" id="pages" pos="15 30" size="160 203">
        <view id="pageInProgress">
            <text color="black" label="$(com.minecolonies.coremod.item.questlog.gui.inprogress)" pos="0 0" size="100% 11" textalign="MIDDLE"/>

            <list id="quests" pos="0 15" size="160 187">
                <view size="100% 45">
                    <text color="black" id="questName" pos="0 0" size="130 11"/>
                    <text color="black" id="questGiver" pos="0 15" size="130 11"/>
                    <text color="black" id="questObjective" pos="0 30" size="130 11"/>
                    <button id="questLocator" pos="135 0" size="15 22" source="minecolonies:textures/gui/quest-locator.png"/>
                </view>
            </list>
        </view>
        <view id="pageAvailable">
            <text color="black" label="$(com.minecolonies.coremod.item.questlog.gui.available)" pos="0 0" size="100% 11" textalign="MIDDLE"/>

            <list id="quests" pos="0 15" size="160 187">
                <view size="100% 30">
                    <text color="black" id="questName" pos="0 0" size="130 11"/>
                    <text color="black" id="questGiver" pos="0 15" size="130 11"/>
                    <button id="questLocator" pos="135 0" size="15 22" source="minecolonies:textures/gui/quest-locator.png"/>
                </view>
            </list>
        </view>
        <view id="pageFinished">
            <text color="black" label="$(com.minecolonies.coremod.item.questlog.gui.finished)" pos="0 0" size="100% 11" textalign="MIDDLE"/>

            <list id="quests" pos="0 15" size="160 187">
                <view size="100% 30">
                    <text color="black" id="questName" pos="0 0" size="130 11"/>
                    <text color="black" id="questCompletedCount" pos="0 15" size="130 11"/>
                </view>
            </list>
        </view>
    </switch>
</window>
