<window size="524 290">
    <layout source="minecolonies:gui/townhall/windowtownhall.xml"/>
    <switch id="pages" pos="75 0" size="374 290">
        <view id="pageAddPlayer" size="374 290">
            <text color="black" label="$(com.minecolonies.coremod.gui.townhall.addplayer)" pos="26 65" size="148 11"/>
            <input id="addPlayerName" maxlength="32" pos="26 76" size="100 18"/>
            <button id="addPlayer" label="+" pos="130 78" size="14 15" source="minecolonies:textures/gui/builderhut/builder_button_mini.png" textcolor="black"/>

            <list id="users" pos="26 100" size="148 121">
                <box linewidth="1" size="100% 35">
                    <text color="black" id="name" pos="5 2" size="100 11"/>
                    <button align="TOP_RIGHT" id="removePlayer" pos="2 1" size="14 15" source="minecolonies:textures/gui/button_x.png"/>
                    <text color="black" id="rank" pos="5 17" size="129 11"/>
                    <dropdown
                        color="black"
                        dropDownSize="129 45"
                        dropfixx="276"
                        id="rankPicker"
                        maxContentHeight="45"
                        pos="2 17"
                        scrollbarOffset="9 0"
                        size="129 17"
                        source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png">
                        <view size="100% 15">
                            <text id="id" label="" pos="0 0" size="100% 100%" textalign="MIDDLE"/>
                            <button color="black" id="button" pos="0 0" size="129 17" source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>
                        </view>
                    </dropdown>
                </box>
            </list>

            <text color="black" label="$(com.minecolonies.coremod.gui.townhall.permevents):" pos="196 39" size="148 11" textalign="MIDDLE"/>

            <list id="eventsList" pos="196 50" size="148 152">
                <box linewidth="1" size="100% 36">
                    <text color="black" id="action" pos="1 1" size="140 12"/>
                    <text color="blue" id="name" pos="1 12" size="100 12"/>
                    <text color="black" id="pos" pos="1 24" size="70 12"/>
                    <button id="addfakeplayer" label="$(com.minecolonies.coremod.gui.townhall.add)" pos="105 10" size="35 14"/>
                </box>
            </list>
        </view>
        <view id="managePermissions">
            <text color="black" label="$(com.minecolonies.coremod.gui.townhall.addrank)" pos="36 65" size="148 11"/>
            <input id="addRankName" maxlength="32" pos="36 80" size="100 18"/>
            <button id="buttonAddRank" label="+" pos="140 82" size="14 15" source="minecolonies:textures/gui/builderhut/builder_button_mini.png" textcolor="black"/>

            <list id="rankButtonList" pos="46 105" size="100 110">
                <box linewidth="0" size="100% 15">
                    <text id="rankId"/>
                    <button color="black" id="rankButton" pos="2 2" size="86 15" source="minecolonies:textures/gui/builderhut/builder_button_medium.png"/>
                </box>
            </list>

            <text color="black" id="rankType" label="Type:" pos="201 41" size="50 11"/>
            <dropdown
                color="black"
                dropDownSize="129 100"
                dropfixx="276"
                id="rankTypePicker"
                maxContentHeight="100"
                pos="244 38"
                scrollbarOffset="9 0"
                size="86 17"
                source="minecolonies:textures/gui/builderhut/builder_button_medium.png">
                <view size="100% 15">
                    <text id="id" label="" pos="0 0" size="100% 100%" textalign="MIDDLE"/>
                    <button color="black" id="button" pos="0 0" size="86 17" source="minecolonies:textures/gui/builderhut/builder_button_medium.png"/>
                </view>
            </dropdown>

            <text color="black" id="isSubscriber" label="Is Subscriber:" pos="201 60" size="98 11"/>
            <button
                color="black"
                id="setSubscriber"
                label="$(com.minecolonies.coremod.gui.workerhuts.retrieveOff)"
                pos="301 57"
                size="29 15"
                source="minecolonies:textures/gui/builderhut/builder_button_very_small.png"/>

            <list id="rankList" pos="201 77" size="138 120">
                <box linewidth="1" size="100% 21">
                    <text color="black" id="name" pos="2 2" size="110 18"/>
                    <button
                        align="TOP_RIGHT"
                        color="black"
                        id="trigger"
                        label="$(com.minecolonies.coremod.gui.workerhuts.retrieveoff)"
                        pos="2 3"
                        size="29 15"
                        source="minecolonies:textures/gui/builderhut/builder_button_very_small.png"/>
                    <text id="index" pos="100 100"/>
                </box>
            </list>

            <button
                color="red"
                id="removeRank"
                label="$(com.minecolonies.coremod.gui.townhall.removerank)"
                pos="201 200"
                size="129 17"
                source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>
        </view>
        <!-- todo adjust this, separate blocks and pos, and make pos list a pos-start to pos-end -->
        <view id="freeBlockList">
            <text color="black" label="$(com.minecolonies.coremod.gui.townhall.freeblocks)" pos="201 24" size="148 11"/>

            <text color="black" label="$(com.minecolonies.coremod.gui.townhall.addblock)" pos="26 65" size="146 11"/>
            <input id="addBlockName" maxlength="32" pos="26 76" size="100 18"/>
            <button id="addBlock" label="+" pos="130 78" size="14 15" source="minecolonies:textures/gui/builderhut/builder_button_mini.png" textcolor="black"/>
            <button id="blockTool" pos="146 78" size="14 15" source="minecolonies:textures/gui/scepterpermission.png"/>

            <list id="blocks" pos="201 36" size="148 171">
                <box linewidth="1" size="100% 30">
                    <text color="black" id="name" pos="5 2" size="115 28" textalign="TOP_LEFT" wrap="true"/>
                    <button align="TOP_RIGHT" id="removeBlock" pos="2 1" size="14 15" source="minecolonies:textures/gui/button_x.png"/>
                </box>
            </list>
        </view>
    </switch>
    <button id="prevPage" pos="100 24" size="18 10" source="minecolonies:textures/gui/builderhut/turn_page_left.png"/>
    <button id="nextPage" pos="406 24" size="18 10" source="minecolonies:textures/gui/builderhut/turn_page_right.png"/>
    <text color="black" id="pageNum" label="" pos="406 211" size="18 9" textalign="MIDDLE"/>
</window>
