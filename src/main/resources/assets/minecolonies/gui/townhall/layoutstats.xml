<window size="524 243">
    <layout source="minecolonies:gui/townhall/windowtownhall.xml"/>
    <text color="black" label="$(com.minecolonies.coremod.gui.townhall.population.totalcitizens)" pos="100 61" size="110 11"/>
    <text color="black" id="totalCitizens" pos="215 61" size="50 11"/>
    <list id="citizen-stats" pos="100 83" size="148 136">
        <box linewidth="0" size="100% 11">
            <text color="black" id="citizensAmount" size="100% 11"/>
        </box>
    </list>

    <view pos="270 0" size="200 243">
        <dropdown dropDownSize="140 75" id="intervals" maxContentHeight="75" pos="20 45" size="129 17" source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png" textcolor="black">
            <button
                id="button"
                label="$(com.minecolonies.coremod.gui.interval.yesterday)"
                pos="0 0"
                size="129 17"
                source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"
                textcolor="black"/>
        </dropdown>
        <list id="stats" pos="20 65" size="160 135">
            <text color="black" id="desc" pos="0 0" size="160 13"/>
        </list>
    </view>
</window>
