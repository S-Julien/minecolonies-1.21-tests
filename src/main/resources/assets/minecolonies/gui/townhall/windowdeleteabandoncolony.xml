<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="400 244"
    type="VANILLA">
    <image size="400 244" source="minecolonies:textures/gui/builderhut/builder_paper_wide2.png"/>

    <button color="black" id="cancel" pos="375 10" size="14 15" source="minecolonies:textures/gui/button_x.png"/>

    <text color="black" id="warningtext" pos="70 15" size="260 120" textalign="MIDDLE" textscale="1"/>

    <button
        color="black"
        disabled="minecolonies:textures/gui/builderhut/builder_button_medium_large_disabled.png"
        id="pickup"
        label="$(com.minecolonies.core.founding.pickup)"
        pos="70 150"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>

    <button
        color="black"
        disabled="minecolonies:textures/gui/builderhut/builder_button_medium_large_disabled.png"
        id="delete"
        label="$(com.minecolonies.core.founding.delete)"
        pos="200 150"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>

    <button
        color="black"
        disabled="minecolonies:textures/gui/builderhut/builder_button_medium_large_disabled.png"
        id="abandon"
        label="$(com.minecolonies.core.founding.abandon)"
        pos="130 180"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>

    <image id="dialog" pos="72 35" size="256 180" source="minecolonies:textures/gui/dialog.png" visible="false"/>

    <text color="black" hide="true" id="confirmtext" pos="100 30" size="200 120" textalign="MIDDLE" textscale="1" visible="false"/>

    <button
        color="black"
        id="confirmdelete"
        label="$(com.minecolonies.core.gui.colony.delete.confirm)"
        pos="110 160"
        size="86 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium.png"
        visible="false"/>

    <button
        color="black"
        id="confirmabandon"
        label="$(com.minecolonies.core.gui.colony.abandon.confirm)"
        pos="110 160"
        size="86 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium.png"
        visible="false"/>

    <button
        color="black"
        id="cancelaction"
        label="$(com.minecolonies.core.gui.colony.manage.cancel)"
        pos="210 160"
        size="86 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium.png"
        visible="false"/>
</window>
