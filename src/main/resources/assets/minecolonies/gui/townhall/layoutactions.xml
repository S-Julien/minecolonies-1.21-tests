<window size="524 243">
    <layout source="minecolonies:gui/townhall/windowtownhall.xml"/>
    <text color="green" label="$(com.minecolonies.coremod.gui.townhall.currtownhallname)" pos="100 24" size="148 11"/>
    <text color="black" id="name" pos="120 35" size="148 11"/>

    <button id="rename" pos="100 32" size="15 15" source="minecolonies:textures/gui/builderhut/edit.png" tooltip="$(com.minecolonies.gui.edit)"/>

    <!-- Body left side-->

    <!-- todo search for "current pack" -->

    <button
        id="build"
        label="🔨🔨🔨🔨$(com.minecolonies.coremod.gui.townhall.build)"
        pos="110 97"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large_build.png"
        textcolor="black"/>

    <button
        id="map"
        label="$(com.minecolonies.coremod.gui.townHall.map)"
        pos="110 116"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large_map.png"
        textcolor="black"/>

    <button
        id="mercenaries"
        label="$(com.minecolonies.coremod.gui.townhall.mercenary)"
        pos="110 136"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large_merc.png"
        textcolor="black"/>

    <!-- Visual Changes, Right Side -->

    <text color="black" label="$(com.minecolonies.coremod.gui.townhall.visual)" pos="280 35" size="129 11" textalign="MIDDLE"/>

    <button
        id="bannerPicker"
        label="$(com.minecolonies.coremod.gui.townhall.edit_flag)"
        pos="280 57"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large_banner.png"
        textcolor="black"/>
    bu
    <text color="black" id="pickColor" label="$(com.minecolonies.coremod.gui.townhall.pickteamcolor)" pos="269 83" size="148 11"/>
    <dropdown
        dropDownSize="86 75"
        dropfixx="75"
        id="colorPicker"
        maxContentHeight="75"
        pos="337 80"
        scrollbarOffset="9 0"
        size="86 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium.png"
        textcolor="black">
        <view size="100% 15">
            <button id="button" pos="0 0" size="86 17" source="minecolonies:textures/gui/builderhut/builder_button_medium.png" textcolor="black"/>
        </view>
    </dropdown>

    <text color="black" label="$(com.minecolonies.coremod.gui.townhall.pickcolonystyle)" pos="269 108" size="148 11"/>
    <button
        disabled="minecolonies:textures/gui/builderhut/builder_button_medium_disabled.png"
        id="colonyStylePicker"
        pos="337 105"
        size="86 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium.png"
        textcolor="black"/>

    <button
        id="patreon"
        label="$(com.minecolonies.coremod.gui.townhall.patreon)"
        pos="288 133"
        size="120 19"
        source="minecolonies:textures/gui/patreonwidget.png"
        tooltip="$(com.minecolonies.coremod.gui.townhall.patreon.hover)"/>

    <text color="black" label="$(com.minecolonies.coremod.gui.townhall.picktexturestyle)" pos="269 168" size="148 11"/>
    <dropdown
        disabled="minecolonies:textures/gui/builderhut/builder_button_medium_disabled.png"
        dropDownSize="86 55"
        dropfixx="75"
        enabled="false"
        id="textureStylePicker"
        maxContentHeight="75"
        pos="337 165"
        scrollbarOffset="9 0"
        size="86 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium.png"
        textcolor="black">
        <view size="100% 15">
            <button id="button" pos="0 0" size="86 17" source="minecolonies:textures/gui/builderhut/builder_button_medium.png" textcolor="black"/>
        </view>
    </dropdown>
    <button
        id="resettexture"
        pos="337 165"
        size="86 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium.png"
        text="$(com.minecolonies.gui.reset)"
        textcolor="black"
        visible="false"/>

    <text color="black" label="$(com.minecolonies.coremod.gui.townhall.picknamestyle)" pos="269 193" size="148 11"/>
    <dropdown
        disabled="minecolonies:textures/gui/builderhut/builder_button_medium_disabled.png"
        dropDownSize="86 30"
        dropfixx="30"
        enabled="false"
        id="nameStylePicker"
        maxContentHeight="30"
        pos="337 190"
        scrollbarOffset="9 0"
        size="86 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium.png"
        textcolor="black">
        <view size="100% 15">
            <button id="button" pos="0 0" size="86 17" source="minecolonies:textures/gui/builderhut/builder_button_medium.png" textcolor="black"/>
        </view>
    </dropdown>
</window>
