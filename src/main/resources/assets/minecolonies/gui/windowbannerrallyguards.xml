<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image pos="0 0" size="190 244" source="minecolonies:textures/gui/builderhut/builder_paper.png"/>

    <text color="black" label="$(item.minecolonies.banner_rally_guards)" pos="30 14" size="130 11" textalign="MIDDLE"/>
    <box linewidth="1" pos="16 30" size="158 178">
        <list id="guardtowers" size="100% 100%">
            <box id="guardtower" linewidth="1" size="100% 44">
                <!--Item icon -->
                <itemicon id="guardicon" pos="1 3" size="16 16"/>
                <!--Request name-->
                <text color="black" id="guardtype" pos="20 1" size="130 12"/>
                <text color="black" id="position" pos="20 13" size="130 12"/>
                <!-- button to cancel the request-->
                <button
                    color="black"
                    id="remove"
                    label="$(com.minecolonies.coremod.item.bannerrallyguards.gui.remove)"
                    pos="74 25"
                    size="74 16"
                    source="minecolonies:textures/gui/citizen/colonist_button_medium.png"/>
            </box>
        </list>
    </box>
    <button color="black" id="rally" pos="20 213" size="147 16" source="minecolonies:textures/gui/citizen/colonist_button_big.png"/>
</window>
