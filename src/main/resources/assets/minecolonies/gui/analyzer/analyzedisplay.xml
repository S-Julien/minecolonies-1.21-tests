<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="420 240">
    <button id="selectleft" label="&lt;" pos="1 1" size="14 30" textcolor="black"/>
    <button id="selectright" label="&gt;" pos="126 1" size="14 30" textcolor="black"/>
    <button id="viewschem" pos="15 1" size="111 30" text="none"/>
    <button id="selectschematic" label="$(com.minecolonies.coremod.gui.analyzer.select)" pos="15 30" size="111 15"/>

    <box id="results" label="list" linewidth="1" pos="1 45" size="100% 165">
        <text color="white" id="score" pos="3 1" size="100% 14"/>
        <text color="white" id="size" pos="3 15" size="100% 14"/>
        <text color="white" id="blockcounts" pos="3 29" size="100% 14"/>
        <text color="white" id="buildings" pos="3 43" size="100% 14"/>
        <button
            id="showresources"
            label="$(com.ldtteam.structurize.gui.scantool.showres)"
            pos="3 57"
            size="86 20"
            source="structurize:textures/gui/builderhut/builder_button_medium.png"
            textcolor="black"/>
        <list childspacing="-1" id="resources" pos="0 57" size="100% 120" visible="false">
            <box linewidth="1" size="100% 19">
                <itemicon id="resourceIcon" pos="1 1" size="16 16"/>
                <text color="white" id="resourceName" pos="19 1" size="86 12" wrap="true"/>
                <text color="white" id="resourceCount" pos="105 1" size="30 12" wrap="true"/>
            </box>
        </list>
    </box>

    <button id="cancel" pos="235 250" size="32" source="minecolonies:textures/gui/button_x.png"/>
</window>
