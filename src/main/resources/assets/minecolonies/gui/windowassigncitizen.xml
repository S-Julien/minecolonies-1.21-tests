<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd">
    <image size="400 244" source="minecolonies:textures/gui/builderhut/builder_paper_wide2.png"/>

    <text color="black" label="$(com.minecolonies.coremod.gui.assigning.description)" pos="0 20" size="100% 11" textalign="MIDDLE"/>

    <list id="assigned" pos="10 40" size="190 160">
        <view size="100% 34">
            <gradient gradientend="430265344" gradientstart="430265344" size="100% 100%"/>
            <text color="blue" id="citizen" pos="5 2" size="100% 12"/>
            <button
                color="black"
                id="fire"
                label="$(com.minecolonies.coremod.gui.hiring.buttonfire)"
                pos="120 2"
                size="44 10"
                source="minecolonies:textures/gui/builderhut/builder_button_quite_small.png"
                textscale="0.8"/>

            <text color="black" id="job" pos="5 13" size="175 20" textalign="TOP_LEFT"/>
        </view>
    </list>

    <list id="unassigned" pos="201 40" size="190 160">
        <view size="100% 34">
            <gradient gradientend="430265344" gradientstart="430265344" size="100% 100%"/>
            <text color="blue" id="citizen" pos="5 2" size="100% 12"/>
            <button
                color="black"
                id="hire"
                label="$(com.minecolonies.coremod.gui.hiring.buttonassign)"
                pos="120 2"
                size="44 10"
                source="minecolonies:textures/gui/builderhut/builder_button_quite_small.png"
                textscale="0.8"/>

            <text color="black" id="job" pos="5 13" size="175 20" textscale="0.8"/>
        </view>
    </list>

    <text color="black" id="buildingassignmentmode" label="$(com.minecolonies.coremod.gui.buildingassignmentmode)" pos="40 210" size="200 11"/>
    <button color="black" id="mode" pos="170 207" size="169 17" source="minecolonies:textures/gui/builderhut/builder_button_large.png"/>

    <button color="black" id="cancel" pos="375 10" size="14 15" source="minecolonies:textures/gui/button_x.png"/>
</window>
