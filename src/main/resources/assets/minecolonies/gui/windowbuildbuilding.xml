<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    lightbox="true">
    <button color="black" id="previousStyle" label="&lt;" pos="40 0" size="14 15" source="minecolonies:textures/gui/builderhut/builder_button_mini.png"/>
    <dropdown color="black" dropDownSize="140 75" id="style" maxContentHeight="75" pos="55 0" size="129 17" source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png">
        <view size="100% 15">
            <text id="id" label="" pos="0 0" size="100% 100%"/>
            <button color="black" id="button" pos="0 0" size="129 17" source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>
        </view>
    </dropdown>
    <button color="black" id="nextStyle" label="&gt;" pos="185 0" size="14 15" source="minecolonies:textures/gui/builderhut/builder_button_mini.png"/>

    <dropdown color="black" dropDownSize="140 75" id="worker" maxContentHeight="75" pos="225 0" size="129 17" source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png">
        <view size="100% 15">
            <text id="id" label="" pos="0 0" size="100% 100%"/>
            <button color="black" id="button" pos="0 0" size="129 17" source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>
        </view>
    </dropdown>

    <button color="black" id="cancel" pos="400 0" size="14 15" source="minecolonies:textures/gui/button_x.png"/>

    <list id="resources" pos="30 20" size="80% 80%">
        <box linewidth="1" size="100% 30">
            <itemicon id="resourceIcon" pos="3 3" size="24 24"/>
            <text color="white" id="resourceName" pos="33 9" size="225 12"/>
            <text align="MIDDLE_RIGHT" color="white" id="resourceQuantity" pos="20 0" size="24 12"/>
        </box>
    </list>
    <button
        align="TOP_MIDDLE"
        color="black"
        id="repair"
        label="$(com.minecolonies.coremod.gui.workerhuts.repair)"
        pos="-120 220"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>
    <button
        align="TOP_MIDDLE"
        color="black"
        id="build"
        label="$(com.minecolonies.coremod.gui.workerhuts.upgrade)"
        pos="10 220"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>
    <button
        align="TOP_MIDDLE"
        color="black"
        id="deconstruct"
        label="$(com.minecolonies.coremod.gui.workerhuts.deconstruct)"
        pos="140 220"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"/>
    <button
        align="TOP_MIDDLE"
        color="black"
        id="pickup"
        label="$(com.minecolonies.coremod.gui.workerhuts.pickup)"
        pos="140 220"
        size="129 17"
        source="minecolonies:textures/gui/builderhut/builder_button_medium_large.png"
        visible="false"/>
</window>
