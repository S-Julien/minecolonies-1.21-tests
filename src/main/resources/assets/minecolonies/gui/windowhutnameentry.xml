<window
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    lightbox="true">
    <text color="white" label="$(com.minecolonies.coremod.gui.building.rename.title)" pos="0 100" size="100% 11" textalign="TOP_MIDDLE"/>
    <input id="name" maxlength="25" pos="135 110" size="150 18"/>
    <button id="done" label="$(gui.done)" pos="110 170" size="200 20"/>
    <button id="cancel" label="$(gui.cancel)" pos="110 194" size="200 20"/>
</window>
